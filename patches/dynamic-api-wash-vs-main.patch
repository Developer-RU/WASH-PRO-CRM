-# =============================================================================
-# Dynamic API Platform — Environment Variables
-# Copy to .env and adjust before production deployment
-# =============================================================================
-
-# --- Application ---
-NODE_ENV=production
-PORT=3001
-
-# --- MongoDB ---
-MONGODB_URI=mongodb://mongodb:27017/dynamic_api
-
-# --- JWT (CHANGE IN PRODUCTION!) ---
-JWT_SECRET=change-me-to-a-long-random-string
-JWT_REFRESH_SECRET=change-me-to-another-long-random-string
-JWT_EXPIRES_IN=15m
-JWT_REFRESH_EXPIRES_IN=7d
-
-# --- CORS ---
-CORS_ORIGIN=http://localhost:8080
-
-# --- Rate limiting ---
-RATE_LIMIT_WINDOW_MS=900000
-RATE_LIMIT_MAX=1000
-
-# --- CSRF ---
-CSRF_SECRET=change-me-csrf-secret
-
-# --- Default admin (seeded on first run) ---
-ADMIN_LOGIN=admin
-ADMIN_EMAIL=admin@dynamic-api.local
-ADMIN_PASSWORD=Admin123!
-
-# --- Frontend build (local dev only) ---
-VITE_API_URL=http://localhost:3001
